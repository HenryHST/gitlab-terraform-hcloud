# Copy to outputs_proxmox.tf together with proxmox.tf when using Proxmox.

output "proxmox_gitlab_vm_id" {
  description = "Proxmox VM ID for module.proxmox GitLab VM when enable_proxmox_resources is true"
  value       = var.enable_proxmox_resources ? module.proxmox[0].gitlab_vm_id : null
}

output "proxmox_gitlab_vm_status" {
  description = "Desired power state of the Proxmox GitLab VM"
  value       = var.enable_proxmox_resources ? module.proxmox[0].gitlab_vm_status : null
}

output "proxmox_gitlab_vm_network" {
  description = "Network configuration and guest-agent addresses for the Proxmox GitLab VM"
  value       = var.enable_proxmox_resources ? module.proxmox[0].gitlab_vm_network : null
}

output "proxmox_gitlab_vm" {
  description = "GitLab VM on Proxmox: id, name, node, status, and network"
  value       = var.enable_proxmox_resources ? module.proxmox[0].gitlab_vm : null
}

output "proxmox_gitlab_cloud_init_snippet" {
  description = "cicustom user= path for GitLab VM cloud-init on Proxmox"
  value       = var.enable_proxmox_resources ? module.proxmox[0].gitlab_cloud_init_snippet : null
}

output "proxmox_runner_vm_id" {
  description = "Proxmox VM ID for module.proxmox runner VM when proxmox_enable_runner is true"
  value       = var.enable_proxmox_resources ? module.proxmox[0].runner_vm_id : null
}

output "proxmox_runner_vm_status" {
  description = "Desired power state of the Proxmox runner VM"
  value       = var.enable_proxmox_resources ? module.proxmox[0].runner_vm_status : null
}

output "proxmox_runner_vm_network" {
  description = "Network configuration and guest-agent addresses for the Proxmox runner VM"
  value       = var.enable_proxmox_resources ? module.proxmox[0].runner_vm_network : null
}

output "proxmox_runner_vm" {
  description = "Runner VM on Proxmox when proxmox_enable_runner is true; null otherwise"
  value       = var.enable_proxmox_resources ? module.proxmox[0].runner_vm : null
}
