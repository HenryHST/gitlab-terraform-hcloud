# Copy to provider_proxmox.tf together with proxmox.tf when enable_proxmox_resources = true.
# Without this file, Terraform does not load telmate/proxmox (Hetzner-only plans need no Proxmox API).

terraform {
  required_providers {
    proxmox = {
      source  = "telmate/proxmox"
      version = ">= 3.0.0, <= 3.0.2-rc07"
    }
  }
}

provider "proxmox" {
  pm_api_url          = var.proxmox_api_url
  pm_api_token_id     = var.proxmox_api_token_id
  pm_api_token_secret = var.proxmox_api_token
  pm_tls_insecure     = var.pm_tls_insecure
  pm_timeout          = var.pm_timeout
  pm_parallel         = var.pm_parallel
}
