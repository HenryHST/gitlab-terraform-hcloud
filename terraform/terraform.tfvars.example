# Copy to terraform.tfvars (gitignored) and fill in real values. Do not commit secrets.

# hcloud_token = "…"   # prefer: export TF_VAR_hcloud_token="…"

ssh_public_key_file = "~/.ssh/id_ed25519.pub"
ssh_public_key      = ""

server_name  = "git04"
server_type  = "cpx22"
location     = "fsn1"

# Hetzner DNS API token (https://dns.hetzner.com/) — NOT hcloud_token; docker_compose → HETZNER_API_TOKEN in Traefik .env
hetzner_api_key = "your_hetzner_dns_api_key_here"

dns_domain = "example.com"
create_hcloud_dns_zone  = false

mail_mx_value = "10 mail.example.com"
dmarc_value   = "v=DMARC1;p=quarantine;pct=100;rua=mailto:info@example.com"
dkim_value    = ""
spf_value     = "v=spf1 mx -all"
tlsa_value    = ""
srv_value     = "0 0 443 example.com."

# Mail A/AAAA/CNAME/TLSA name (see variables.tf); align spf_value ip4: with mail_server_ipv4 if used
# mail_server_ipv4         = "203.0.113.10"
# mail_server_ipv6         = "2001:db8::10"
# mail_server_cname_target = "mail.example.com"
# dns_tlsa_name            = "_25._tcp.mail.example.com"

iodef_value   = "mailto:info@example.com"
contact_value = "mailto:info@example.com"

gitlab_letsencrypt_enabled         = false
gitlab_install_mode                = "none"
# docker_compose + HTTPS (Traefik DNS-01): set install_mode = "docker_compose" and:
# gitlab_docker_traefik_acme_enabled = true
# hetzner_api_key = "…"  # Hetzner DNS API token (not hcloud_token)
# gitlab_docker_renovate_enabled   = false
# gitlab_docker_renovate_ce_image  = "ghcr.io/mend/renovate-ce:9.1.0"
# gitlab_docker_renovate_license_key = "…"  # Mend CE license
# gitlab_docker_renovate_gitlab_pat  = "glpat-…"
# Container Registry (docker_compose only; default enabled)
# gitlab_docker_registry_enabled   = true
# gitlab_docker_registry_dns_label = "registry"
# GitLab Pages (docker_compose / Proxmox-Docker; requires gitlab_docker_traefik_acme_enabled) — docs/pages.md
# gitlab_docker_traefik_acme_enabled = true
# gitlab_docker_pages_enabled        = true
# gitlab_docker_pages_dns_label      = "pages"
enable_gitlab_runner    = false
enable_gitlab_resources = false
# gitlab_early_auth_check = false   # true only when gitlab_api_url is reachable at plan time
# gitlab_api_token   = "…"   # required when enable_gitlab_resources = true
# Self-hosted (docker_compose): instance URL, not https://gitlab.com
# gitlab_api_url     = "https://gitlab.example.com"
# gitlab_letsencrypt_email  = "info@example.com"
# gitlab_root_email         = ""   # docker_compose / Proxmox: root email (GITLAB_ROOT_EMAIL); empty = gitlab_letsencrypt_email or gitlab-root@<zone>

# Docker host admin (docker_compose / Proxmox-Docker; SSH with same key as root)
# gitlab_admin = { enabled = true }
# gitlab_admin = { enabled = true, username = "gadmin" }

# Host hardening (docker_compose / Proxmox-Docker): jq, ufw, fail2ban, sshd, sysctl, unattended-upgrades
# gitlab_docker_host_hardening = { enabled = true }
# gitlab_docker_host_hardening = {
#   enabled             = true
#   ufw_enable_dns      = false
#   ufw_enable_icmp     = true
#   ufw_ssh_source_ips  = ["203.0.113.4/32"]
#   unattended_upgrades = true
# }

# Traefik HTTP hardening (docker_compose / Proxmox-Docker): fail2ban plugin, log level, rate limit, TLS
# gitlab_docker_traefik_hardening = { enabled = true }
# gitlab_docker_traefik_hardening = {
#   enabled            = true
#   fail2ban_enabled   = true
#   log_level          = "INFO"
#   access_log_format  = "json"
#   rate_limit_enabled = true
#   rate_limit_average = 100
#   rate_limit_burst   = 200
#   tls_min_version    = "VersionTLS12" # or VersionTLS13
# }

# Docker Engine / Compose hardening: daemon.json, no-new-privileges, container log rotation
# gitlab_docker_compose_hardening = { enabled = true }
# gitlab_docker_compose_hardening = {
#   enabled                     = true
#   daemon_icc_disabled         = true
#   daemon_live_restore         = true
#   daemon_userland_proxy       = false
#   log_max_size                = "10m"
#   log_max_file                = 3
#   container_no_new_privileges = true
#   container_log_rotation      = true
# }

# PostgreSQL image (docker_compose) — e.g. postgres:16-bookworm; GitLab 19.x → postgres:17 via effective image
# gitlab_docker_postgres_image = "postgres:16-bookworm"
# GitLab 19.x (requires postgres:17 — set gitlab_docker_postgres_image = "postgres:17-alpine"):
# gitlab_docker_gitlab_ce_image = "gitlab/gitlab-ce:19.1.1-ce.0"

# GitLab DB connection tuning + optional PgBouncer (docker_compose)
# gitlab_docker_db_tuning = { enabled = true }
# gitlab_docker_db_tuning = {
#   enabled                     = true
#   db_pool                     = 32
#   sidekiq_concurrency         = 20
#   pgbouncer_enabled           = true
#   pgbouncer_image             = "edoburu/pgbouncer:1.24.1"
#   pgbouncer_pool_mode         = "transaction"
#   pgbouncer_default_pool_size = 25
#   pgbouncer_max_client_conn   = 2048
# }

# Backups (docker_compose, hetzner_app, proxmox) — see docs/backup.md
# gitlab_docker_backup_enabled       = true
# gitlab_docker_backup_auto_enabled  = true   # false = scripts only, no /etc/cron.d/gitlab-backup
# gitlab_docker_backup_time          = "03:00" # HH:MM when gitlab_docker_backup_cron is empty
# gitlab_docker_backup_cron          = ""      # optional override, e.g. "0 2 * * 0"
# gitlab_docker_backup_keep_time     = 604800  # 7 days; 0 = keep all

# Sign-up on login page (docker_compose only) — gitlab_rails['gitlab_signup_enabled'] in gitlab.rb
# gitlab_signup_enabled = false

# Initial root password on GitLab sign-in page (docker_compose only; first DB seed only)
# gitlab_display_initial_root_password = true
# gitlab_display_initial_root_password = false  # use terraform output gitlab_docker_initial_root_password only

# GitLab Runner in same Compose stack (https://docs.gitlab.com/tutorials/automate_runner_creation/)
# gitlab_docker_runner_enabled        = false
# gitlab_docker_runner_autoregister   = true   # empty token → POST /api/v4/user/runners after bootstrap
# gitlab_docker_runner_token          = ""     # or glrt-… from UI when autoregister = false
# gitlab_docker_runner_description    = "docker-compose"
# gitlab_docker_runner_tags           = ["docker"]
# Buildah: three runners instead of one generic — docs/runner-buildah.md
# gitlab_docker_runner_buildah_enabled       = true
# gitlab_docker_runner_buildah_default_image = "quay.io/buildah/stable"

# PlantUML in Compose (https://docs.gitlab.com/administration/integration/plantuml/)
# gitlab_docker_plantuml_enabled = true
# gitlab_docker_plantuml_image   = "plantuml/plantuml-server:tomcat"

# CI job artifacts (https://docs.gitlab.com/administration/cicd/job_artifacts/) — host: /opt/gitlab/artifacts/data
# artifacts_enabled = true
# artifacts_path    = "/var/opt/gitlab/gitlab-rails/shared/artifacts"

# Outbound mail (docker_compose only) — written to /opt/gitlab/data/config/gitlab.rb
# gitlab_smtp_enabled              = false
# gitlab_smtp_address              = "smtp.example.com"
# gitlab_smtp_port                 = 587
# gitlab_smtp_user_name            = "gitlab"
# gitlab_smtp_password             = "…"
# gitlab_smtp_domain               = ""   # empty = dns_domain
# gitlab_smtp_authentication       = "login"
# gitlab_smtp_enable_starttls_auto = true
# gitlab_smtp_tls                  = false
# gitlab_email_from                = "gitlab@example.com"
# gitlab_email_reply_to            = "noreply@example.com"
# --- Proxmox (GitLab on QEMU VM) — see README "GitLab auf Proxmox"
# Proxmox (optional; Hetzner docker_compose: leave false and do not copy proxmox*.tf):
# cp proxmox.tf.example proxmox.tf
# cp provider_proxmox.tf.example provider_proxmox.tf
# cp proxmox_variables.tf.example proxmox_variables.tf
# cp outputs_proxmox.tf.example outputs_proxmox.tf
# cp proxmox_data.tf.example proxmox_data.tf   # required for gitlab_install_mode = "proxmox"
# enable_proxmox_resources              = false
# proxmox_gitlab_docker_compose_enabled = true   # required with enable_proxmox_resources for GitLab on Proxmox
# proxmox_api_url                       = "https://pve01.example.com:8006/api2/json"
# proxmox_api_token                     = "…"
# proxmox_api_token_id                  = "terraform@pve!terraform"
# proxmox_node                          = "pve01"
# proxmox_gitlab_ipconfig0              = "ip=10.20.0.10/16,gw=10.20.0.1"
# proxmox_runner_ipconfig0              = "ip=10.20.0.11/16,gw=10.20.0.1"
# proxmox_enable_runner                 = false
# proxmox_enable_clone                  = false
# pm_tls_insecure                       = true
# pm_timeout                            = 300   # API timeout (seconds); 30–86400
# pm_parallel                           = 1     # parallel provider ops; 1–32
# ciuser                                = "admin"
# cipassword                            = "…"
# nameserver                            = "192.168.0.1"
# searchdomain                          = "example.com"
# vm_default_bridge                     = "vmbr0"
# vm_default_storage                    = "local-lvm"
# clone_template                        = "ubuntu-tmp"
# Proxmox-only (recommended):
# gitlab_install_mode                   = "proxmox"
# enable_proxmox_resources              = true
# proxmox_gitlab_docker_compose_enabled = true
# proxmox_gitlab_vmid                   = 0    # 0 = auto; e.g. 120 = fixed ID (plan checks availability)
# proxmox_runner_vmid                   = 0
# Legacy Proxmox-only: gitlab_install_mode = "none" + enable_proxmox_resources = true
# enable_hetzner_dns = null   # default: no Hetzner DNS when Proxmox is the GitLab target
# enable_hetzner_dns = true   # override: mail zone / runner A record on Hetzner DNS
